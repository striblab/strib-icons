/**
 * Star Tribune icons (strib-icons)
 * Version: {{ pkg.version }}
 * Copyright Star Tribune
 */

@font-face {
	font-family: "{{name}}";
	src: {{{fontSrc}}};
}

{{selector}} {
	line-height: 1;
}

{{selector}}:before {
	font-family: {{name}} !important;
	font-style: normal;
	font-weight: normal !important;
	vertical-align: top;
}

{{#each codepoints}}
.{{../prefix}}{{@key}}:before {
	content: "\\{{this}}";
}
{{/each}}

/* SVG includes */
{{selector}}-svg {
	display: inline-block;
	width: 1em;
	height: 1em;
}
